{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Station": ""
  },
  "Auth": {
    "AdminOrigin": "",
    "SessionLifetimeHours": 12
  },
  "DataProtection": {
    "KeyRingPath": "/var/lib/genwave/dp-keys"
  },
  "Admin": {
    "PlayHistoryCapacity": 50
  },
  "Loudness": {
    "TargetLufs": -16.0,
    "CeilingDbtp": -1.0
  },
  "Library": {
    "Scan": {
      "MissThreshold": 2
    },
    "YearLookup": {
      "Enabled": true,
      "Endpoint": "https://musicbrainz.org/ws/2",
      "MinScore": 90
    },
    "CueDetection": {
      "MinSilenceDurationSec": 0.5
    },
    "Energy": {
      "WindowSeconds": 12.0
    }
  },
  "Llm": {
    "TimeoutSeconds": 10,
    "MaxCopyChars": 450,
    "DegradationPin": "auto"
  },
  "Tts": {
    "BlurbRetentionHours": 24
  },
  "PersonaRanker": {
    "BiasGain": 1.0,
    "EnergyPull": 2.0,
    "Temperature": 0.7,
    "TopK": 18,
    "ExplorationRate": 0.15
  },
  "Station": {
    "SpectatorMode": false,
    "Cadence": {
      "LeadInBeforeEachTrack": true,
      "BackAnnounceAfterEachTrack": true,
      "StationIdEveryNUnits": 4
    },
    "Rotation": {
      "RecentWindow": 20,
      "ArtistSeparation": 2
    },
    "Envelope": {
      "EnergyMin": 0.0,
      "EnergyMax": 1.0
    },
    "Requests": {
      "Enabled": false,
      "OverrideEnvelope": true,
      "WindowMinutes": 15
    },
    "SafeScope": {
      "LibraryIds": [ 1 ]
    },
    "Persona": {
      "ActiveId": 0
    }
  },
  "GW_XFADE_MIN": "2",
  "GW_XFADE_MAX": "8",
  "GW_SAFE_GAP_SECONDS": "7"
}
