<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Central package management (NU1507) requires a single source or explicit source mapping.
       GenWave consumes public packages only, so: clear anything inherited from machine/user
       config (e.g. an internal feed on a CI runner) and pin nuget.org. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
