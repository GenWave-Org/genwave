# .env.example — copy to .env and fill in. compose.yaml reads these via ${VAR:?} and will
# refuse to start (with a clear error) if a required one is missing. NEVER commit the real .env.
#
#   cp .env.example .env   # then edit
#
# Quote any value containing spaces (e.g. STATION_NAME="GWAV 108.8"). Compose strips the
# surrounding quotes on substitution, and quoting keeps the file safe to `source` in scripts.

# Station name shown on listeners' radios (icy-name header + StreamTitle prefix) and fed to the
# API as Station__Name. Optional — defaults to "GWAV 108.8".
#STATION_NAME="My GenWave Station"

# Absolute path to your music library on the host. Both the engine and the api mount it read-only at
# /media (the engine plays, the library scans + analyses; neither writes).
MEDIA_DIR=/absolute/path/to/your/music/library

# Postgres superuser password (owns the `genwave` database; used by db init).
POSTGRES_PASSWORD=change-me-postgres

# Password for the dedicated `library_svc` role — the only DB login the api uses.
# Created on first db boot by db/01-library.sh; the api connects with it via ConnectionStrings__Library.
LIBRARY_DB_PASSWORD=change-me-library

# Password for the dedicated `station_svc` role — used by the api for station settings/personas.
# Created on first db boot by db/06-station-settings-migration.sh; the api connects with it via
# ConnectionStrings__Station.
STATION_DB_PASSWORD=change-me-station

# Icecast source password — the engine uses this to connect as the stream source.
ICECAST_SOURCE_PASSWORD=change-me-source

# Icecast admin password — guards /admin. Make it strong.
ICECAST_ADMIN_PASSWORD=change-me-admin

# Single admin password for the Admin UI login (no user table — one deployment, one station).
# REQUIRED for any admin access: leave blank and the admin plane fail-closes — every admin
# endpoint denies and login can never succeed (no local-dev open mode).
ADMIN_PASSWORD=change-me-admin-ui
