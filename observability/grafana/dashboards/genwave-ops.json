{
  "uid": "genwave-ops",
  "title": "GenWave Ops",
  "description": "Prove-the-pipe Ops board (SPEC F78.9, STORY-204): per-service log volume, error/warn rate, live error tail, and per-service totals — sliced by station/env, contract labels only (observability/LABELS.md).",
  "tags": ["genwave"],
  "editable": false,
  "graphTooltip": 1,
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "station",
        "label": "Station",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(station)",
        "definition": "label_values(station)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      },
      {
        "name": "env",
        "label": "Env",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(env)",
        "definition": "label_values(env)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log volume by service",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "range",
          "expr": "sum by (service) (count_over_time({station=~\"$station\", env=~\"$env\"}[$__interval]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error / warn rate by service",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "range",
          "expr": "sum by (service) (count_over_time({station=~\"$station\", env=~\"$env\"} |~ `(?i)error`[$__interval]))",
          "legendFormat": "{{service}} error"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "range",
          "expr": "sum by (service) (count_over_time({station=~\"$station\", env=~\"$env\"} |~ `(?i)warn`[$__interval]))",
          "legendFormat": "{{service}} warn"
        }
      ]
    },
    {
      "id": 3,
      "title": "Recent errors",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "range",
          "expr": "{station=~\"$station\", env=~\"$env\"} |~ `(?i)error`"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total log lines by service (range)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum by (service) (count_over_time({station=~\"$station\", env=~\"$env\"}[$__range]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Error lines by service (range)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum by (service) (count_over_time({station=~\"$station\", env=~\"$env\"} |~ `(?i)error`[$__range]))",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
