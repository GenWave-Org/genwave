<!-- icecast/icecast.xml.tmpl — hardened single-mount config for a private station.
     ${ICECAST_SOURCE_PASSWORD} / ${ICECAST_ADMIN_PASSWORD} are filled in by entrypoint.sh.
     Intentionally NO <directory> (YP) block: the station is not advertised publicly.
     Intentionally NO <changeowner>: the container already runs as the unprivileged icecast2 user. -->
<icecast>
  <limits>
    <clients>1000</clients>
    <sources>2</sources>                  <!-- the engine source + one spare; no open slots -->
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65535</burst-size>
  </limits>

  <authentication>
    <source-password>${ICECAST_SOURCE_PASSWORD}</source-password>
    <relay-password>${ICECAST_SOURCE_PASSWORD}</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>${ICECAST_ADMIN_PASSWORD}</admin-password>
  </authentication>

  <listen-socket>
    <port>8000</port>
    <bind-address>0.0.0.0</bind-address>  <!-- required: listeners + the engine source reach it over the Docker network -->
  </listen-socket>

  <mount type="normal">
    <mount-name>/stream</mount-name>
    <max-listeners>1000</max-listeners>
    <public>0</public>                    <!-- not listed in public directories -->
    <hidden>1</hidden>
  </mount>

  <fileserve>0</fileserve>                <!-- do not serve arbitrary files off disk -->

  <paths>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
    <alias source="/" destination="/status.xsl"/>
  </paths>

  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>                <!-- 3=info; drop to 2 (warn) in production -->
  </logging>

  <!-- NOTE: /admin and /status share the public port 8000. They are password-protected but
       reachable from outside. When you add the TLS reverse proxy (the deferred 5th service),
       block /admin and /status externally and pass only /stream through. Until then, a strong
       ICECAST_ADMIN_PASSWORD is the only guard on admin. -->
</icecast>
