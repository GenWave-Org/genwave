# Secrets — never commit the real environment file
.env

# .NET build output
bin/
obj/
*.user

# Claude session artifacts
# (docs/* not docs/ — a bare `docs/` match excludes the directory itself, and git can never
# re-include a file whose parent directory is excluded, only a directory's *contents*.)
docs/*
# ...except DEPLOYMENT.md — the one public deliverable out of the private planning docs (T19)
!docs/DEPLOYMENT.md

# Smoke-test artifacts
smoke-candidates.json
*.wav

# Playwright MCP session artifacts
.playwright-mcp/

# IDE + OS noise
.idea/
.vs/
TestResults/
.DS_Store
